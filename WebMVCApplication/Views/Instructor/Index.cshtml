@using WebMVCApplication.ViewModels.Instructor
@model List<InstructorDetailsViewModel>

@{
    ViewData["Title"] = "Instructors";
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning text-center">
        <h5 class="mb-0">No Instructors Found</h5>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
 
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Instructors List</h4>

            <a asp-controller="Instructor"
               asp-action="Create"
               class="btn btn-success btn-sm">
                <i class="bi bi-plus-circle"></i> Create
            </a>
        </div>
        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Address</th>
                            <th>Salary</th>
                            <th>Department</th>
                            <th>Course</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var instructor in Model)
                        {
                            <tr>

                                <td>@instructor.Id</td>

                                <td>
                                    <img src="~/Images/@instructor.Image"
                                         alt="@instructor.Name"
                                         class="rounded-circle shadow-sm"
                                         style="width:60px;height:60px;object-fit:cover;" />
                                </td>

                                <td class="fw-semibold">
                                    @instructor.Name
                                </td>

                                <td>
                                    @instructor.Address
                                </td>

                                <td>
                                    <span class="badge bg-success">
                                        @instructor.Salary EGP
                                    </span>
                                </td>

                                <td>
                                    @(instructor.DepartmentName ?? "-")
                                </td>

                                <td>
                                    @(instructor.CourseName ?? "-")
                                </td>

                                <td class="text-center">

                                    <a asp-controller="Instructor"
                                       asp-action="Details"
                                       asp-route-id="@instructor.Id"
                                       class="btn btn-outline-primary btn-sm">
                                        Details
                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>
}