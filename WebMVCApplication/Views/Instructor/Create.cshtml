@using WebMVCApplication.ViewModels.Instructor
@model InstructorCreateNewViewModel

@{
    ViewData["Title"] = "Create Instructor";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-success text-white">
            <h3 class="mb-0">
                <i class="bi bi-person-plus"></i>
                Create New Instructor
            </h3>
        </div>

        <div class="card-body">

            <form asp-action="SaveNew" method="post" enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="InstructorName"
                               class="form-label fw-bold"></label>

                        <input asp-for="InstructorName"
                               class="form-control"
                               placeholder="Enter Instructor Name" />

                        <span asp-validation-for="InstructorName"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="InstructorAddress"
                               class="form-label fw-bold"></label>

                        <input asp-for="InstructorAddress"
                               class="form-control"
                               placeholder="Enter Address" />

                        <span asp-validation-for="InstructorAddress"
                              class="text-danger"></span>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="InstructorSalary"
                               class="form-label fw-bold"></label>

                        <input asp-for="InstructorSalary"
                               type="number"
                               class="form-control" />

                        <span asp-validation-for="InstructorSalary"
                              class="text-danger"></span>
                    </div>

                    @*      <div class="col-md-6 mb-3">
                        <label asp-for="ImageUrl"
                               class="form-label fw-bold"></label>

                        <input asp-for="ImageUrl"
                               class="form-control"
                               placeholder="Enter Image Name" />

                        <span asp-validation-for="ImageUrl"
                              class="text-danger"></span>
                    </div> *@
                    <div class="col-md-6 mb-3">

                        <label asp-for="ImageFile"
                               class="form-label fw-bold">
                            Image
                        </label>

                        <input asp-for="ImageFile"
                               type="file"
                               class="form-control"
                               accept=".jpg,.jpeg,.png" />

                        <span asp-validation-for="ImageFile"
                              class="text-danger"></span>

                    </div>
                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="InstructorDepartmentId"
                               class="form-label fw-bold">
                            Department
                        </label>

                        <select asp-for="InstructorDepartmentId"
                                class="form-select">

                            <option value="">
                                -- Select Department --
                            </option>

                            @foreach (var dept in Model.Departments)
                            {
                                <option value="@dept.DeptId">
                                    @dept.DeptName
                                </option>
                            }

                        </select>

                        <span asp-validation-for="InstructorDepartmentId"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="InstructorCourseId"
                               class="form-label fw-bold">
                            Course
                        </label>

                        <select asp-for="InstructorCourseId"
                                class="form-select">

                            <option value="">
                                -- Select Course --
                            </option>

                            @foreach (var course in Model.Courses)
                            {
                                <option value="@course.CourseId">
                                    @course.CourseName
                                </option>
                            }

                        </select>

                        <span asp-validation-for="InstructorCourseId"
                              class="text-danger"></span>

                    </div>

                </div>

                <hr />

                <button type="submit"
                        class="btn btn-success">
                    <i class="bi bi-check-circle"></i>
                    Save
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Back
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}