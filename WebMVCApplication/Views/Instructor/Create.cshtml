@using WebMVCApplication.ViewModels.Instructor
@model InstructorCreateNewViewModel

@{
    ViewData["Title"] = "Create Instructor";
}
 
<div class="container mt-5">

    <div class="card shadow border-0">

        <div class="card-header bg-success text-white">
            <h4 class="mb-0">Create Instructor</h4>
        </div>

        <div class="card-body">

            <form asp-action="SaveNew" method="post">

                <div asp-validation-summary="All"
                     class="text-danger mb-3">
                </div>

                <div class="mb-3">
                    <label asp-for="InstructorName" class="form-label"></label>
                    <input asp-for="InstructorName" class="form-control" />
                    <span asp-validation-for="InstructorName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="InstructorAddress" class="form-label"></label>
                    <input asp-for="InstructorAddress" class="form-control" />
                    <span asp-validation-for="InstructorAddress" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="InstructorSalary" class="form-label"></label>
                    <input asp-for="InstructorSalary" class="form-control" />
                    <span asp-validation-for="InstructorSalary" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ImageUrl" class="form-label"></label>
                    <input asp-for="ImageUrl" class="form-control" />
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Department</label>

                    <select asp-for="InstructorDepartmentId"
                            class="form-select">

                        <option value="">Select Department</option>

                        @foreach (var dept in Model.Departments)
                        {
                            <option value="@dept.DeptId">
                                @dept.DeptName
                            </option>
                        }

                    </select>

                    <span asp-validation-for="InstructorDepartmentId"
                          class="text-danger">
                    </span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Course</label>

                    <select asp-for="InstructorCourseId"
                            class="form-select">

                        <option value="">Select Course</option>

                        @foreach (var course in Model.Courses)
                        {
                            <option value="@course.CourseId">
                                @course.CourseName
                            </option>
                        }

                    </select>

                    <span asp-validation-for="InstructorCourseId"
                          class="text-danger">
                    </span>
                </div>

                <button type="submit"
                        class="btn btn-success">
                    Save
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>