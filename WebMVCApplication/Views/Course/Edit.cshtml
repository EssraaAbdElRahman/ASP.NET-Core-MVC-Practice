@using WebMVCApplication.ViewModels.Course
@model CourseEditViewModel

@{
    ViewData["Title"] = "Edit Course";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow border-0">

                <div class="card-header bg-primary text-white py-3">
                    <h3 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>
                        Edit Course
                    </h3>
                </div>

                <div class="card-body p-4">

                    <form asp-action="SaveEdit" method="post">

                        <input asp-for="CourseId" type="hidden" />

                        <div asp-validation-summary="All"
                             class="text-danger">
                        </div>

                        <div class="row g-3">

                            <div class="col-md-12">
                                <label asp-for="CourseName"
                                       class="form-label fw-semibold">
                                </label>

                                <input asp-for="CourseName"
                                       class="form-control" />

                                <span asp-validation-for="CourseName"
                                      class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CourseDegree"
                                       class="form-label fw-semibold">
                                </label>

                                <input asp-for="CourseDegree"
                                       type="number"
                                       class="form-control" />

                                <span asp-validation-for="CourseDegree"
                                      class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CourseMinDegree"
                                       class="form-label fw-semibold">
                                </label>

                                <input asp-for="CourseMinDegree"
                                       type="number"
                                       class="form-control" />

                                <span asp-validation-for="CourseMinDegree"
                                      class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CourseHours"
                                       class="form-label fw-semibold">
                                </label>

                                <input asp-for="CourseHours"
                                       type="number"
                                       class="form-control" />

                                <span asp-validation-for="CourseHours"
                                      class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CourseDeptId"
                                       class="form-label fw-semibold">
                                    Department
                                </label>

                                <select asp-for="CourseDeptId"
                                        class="form-select">

                                    @foreach (var dept in Model.Departments)
                                    {
                                        <option value="@dept.DeptId">
                                            @dept.DeptName
                                        </option>
                                    }

                                </select>

                                <span asp-validation-for="CourseDeptId"
                                      class="text-danger"></span>
                            </div>

                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2">

                            <button type="submit"
                                    class="btn btn-primary px-4">
                                <i class="bi bi-save me-1"></i>
                                Update
                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left me-1"></i>
                                Back
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}