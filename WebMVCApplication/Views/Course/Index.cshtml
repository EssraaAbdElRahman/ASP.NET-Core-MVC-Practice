@using WebMVCApplication.ViewModels.Course
@model CourseIndexViewModel

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">

    @if (Model == null || Model.Courses == null || !Model.Courses.Any())
    {
        <div class="card shadow-sm border-0">

            <div class="card-body text-center py-5">

                <i class="bi bi-journal-bookmark display-1 text-secondary"></i>

                <h3 class="mt-3">
                    No Courses Found
                </h3>

                <p class="text-muted">
                    There are currently no courses available.
                </p>

                <a asp-action="Create"
                   class="btn btn-success">

                    <i class="bi bi-plus-circle me-1"></i>
                    Create New Course

                </a>

            </div>

        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3">

            <div class="card-header bg-white py-4">

                <div class="row g-3 align-items-center">

                    <div class="col-md-4">

                        <h3 class="fw-bold mb-1">

                            <i class="bi bi-journal-bookmark-fill text-primary me-2"></i>

                            Courses

                        </h3>

                        <small class="text-muted">
                            Total Courses: @Model.Courses.Count
                        </small>

                    </div>

                    <div class="col-md-5">

                        <form method="get"
                              asp-action="Index">

                            <div class="input-group">

                                <input type="text"
                                       name="search"
                                       value="@Model.Search"
                                       class="form-control"
                                       placeholder="Search courses..." />

                                <button class="btn btn-primary"
                                        type="submit">

                                    <i class="bi bi-search"></i>

                                </button>

                            </div>

                        </form>

                    </div>

                    <div class="col-md-3 text-md-end">

                        <a asp-action="Create"
                           class="btn btn-success">

                            <i class="bi bi-plus-circle me-1"></i>
                            Create Course

                        </a>

                    </div>

                </div>

            </div>

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-hover table-striped align-middle">

                        <thead class="table-light">

                            <tr>
                                <th>ID</th>
                                <th>Course Name</th>
                                <th>Degree</th>
                                <th>Min Degree</th>
                                <th>Hours</th>
                                <th>Department</th>
                                <th class="text-center">Actions</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var course in Model.Courses)
                            {
                                <tr>

                                    <td>
                                        <span class="badge bg-secondary">
                                            @course.CourseId
                                        </span>
                                    </td>

                                    <td class="fw-semibold">
                                        @course.CourseName
                                    </td>

                                    <td>
                                        <span class="badge bg-success px-3 py-2">
                                            @course.CourseDegree
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge bg-warning text-dark px-3 py-2">
                                            @course.CourseMinDegree
                                        </span>
                                    </td>

                                    <td>
                                        @course.CourseHours h
                                    </td>

                                    <td>
                                        @(string.IsNullOrWhiteSpace(course.DeptName)
                                            ? "-"
                                            : course.DeptName)
                                    </td>

                                    <td class="text-center">

                                        <div class="btn-group">

                                            <a asp-action="Details"
                                               asp-route-id="@course.CourseId"
                                               class="btn btn-outline-primary btn-sm">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                            <a asp-action="Edit"
                                               asp-route-id="@course.CourseId"
                                               class="btn btn-outline-warning btn-sm">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">

                <ul class="pagination justify-content-center">

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">

                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-search="@Model.Search">

                                @i

                            </a>

                        </li>
                    }

                </ul>

            </nav>
        }
    }

</div>