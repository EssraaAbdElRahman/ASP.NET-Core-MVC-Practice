@using WebMVCApplication.ViewModels.Course
@model List<CourseDetailsViewModel>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">

    @if (Model == null || !Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">

                <i class="bi bi-journal-bookmark display-1 text-secondary"></i>

                <h3 class="mt-3">No Courses Found</h3>

                <p class="text-muted">
                    There are currently no courses available.
                </p>

                <a asp-action="Create"
                   class="btn btn-success">
                    <i class="bi bi-plus-circle"></i>
                    Create New Course
                </a>

            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">

            <div class="card-header bg-white py-3">

                <div class="d-flex justify-content-between align-items-center">

                    <div>
                        <h3 class="mb-0">
                            <i class="bi bi-journal-bookmark me-2"></i>
                            Courses
                        </h3>

                        <small class="text-muted">
                            Total Courses: @Model.Count
                        </small>
                    </div>

                    <a asp-action="Create"
                       class="btn btn-success">
                        <i class="bi bi-plus-circle"></i>
                        Create
                    </a>

                </div>

            </div>

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Course Name</th>
                                <th>Degree</th>
                                <th>Min Degree</th>
                                <th>Department</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var course in Model)
                            {
                                <tr>

                                    <td>@course.CourseId</td>

                                    <td class="fw-semibold">
                                        @course.CourseName
                                    </td>

                                    <td>
                                        <span class="badge bg-success">
                                            @course.CourseDegree
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge bg-warning text-dark">
                                            @course.CourseMinDegree
                                        </span>
                                    </td>

                                    <td>
                                        @(string.IsNullOrEmpty(course.DeptName)
                                            ? "-"
                                            : course.DeptName)
                                    </td>

                                    <td class="text-center">

                                        <a asp-action="Details"
                                           asp-route-id="@course.CourseId"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-eye"></i>
                                        </a>


                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>
    }

</div>