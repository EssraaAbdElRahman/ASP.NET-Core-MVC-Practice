@using WebMVCApplication.ViewModels.Course
@model CourseCreateNewViewModel

@{
    ViewData["Title"] = "Create Course";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-success text-white">
            <h3 class="mb-0">
                <i class="bi bi-plus-circle"></i>
                Create New Course
            </h3>
        </div>

        <div class="card-body">

            <form asp-action="SaveNew" method="post">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="CourseName" class="form-label fw-bold"></label>

                        <input asp-for="CourseName"
                               class="form-control"
                               placeholder="Enter Course Name" />

                        <span asp-validation-for="CourseName"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="CourseDegee"
                               class="form-label fw-bold"></label>

                        <input asp-for="CourseDegee"
                               type="number"
                               class="form-control" />

                        <span asp-validation-for="CourseDegee"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="CourseMinDegee"
                               class="form-label fw-bold"></label>

                        <input asp-for="CourseMinDegee"
                               type="number"
                               class="form-control" />

                        <span asp-validation-for="CourseMinDegee"
                              class="text-danger"></span>
                    </div>

                </div>

                <div class="mb-4">

                    <label asp-for="CourseDeptId"
                           class="form-label fw-bold">
                        Department
                    </label>

                    <select asp-for="CourseDeptId"
                            class="form-select">

                        <option value="">
                            -- Select Department --
                        </option>

                        @foreach (var dept in Model.Departments)
                        {
                            <option value="@dept.DeptId">
                                @dept.DeptName
                            </option>
                        }

                    </select>

                    <span asp-validation-for="CourseDeptId"
                          class="text-danger"></span>

                </div>

                <hr />

                <button type="submit"
                        class="btn btn-success">
                    <i class="bi bi-check-circle"></i>
                    Save
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Back
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}