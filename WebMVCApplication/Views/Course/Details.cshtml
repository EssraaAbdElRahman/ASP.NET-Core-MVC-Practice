@using WebMVCApplication.ViewModels.Course
@model CourseDetailsViewModel

@{
    ViewData["Title"] = "Course Details";
}

@if (Model == null)
{
    <div class="alert alert-danger text-center mt-4">
        <h5 class="mb-0">Course Not Found</h5>
    </div>
}
else
{
    <div class="container mt-4">

        <div class="card shadow border-0 rounded-3">

            <!-- Header -->
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0 d-flex align-items-center gap-2">
                    <i class="bi bi-book"></i>
                    Course Details
                </h3>
            </div>

            <!-- Body -->
            <div class="card-body p-4">

                <div class="mb-3">
                    <span class="badge bg-secondary fs-6 px-3 py-2">
                        Course ID : @Model.CourseId
                    </span>
                </div>

                <div class="row g-3">

                    <!-- Course Name -->
                    <div class="col-md-6">
                        <label class="form-label text-secondary small mb-1">
                            Course Name
                        </label>
                        <div class="p-2 px-3 bg-light border rounded shadow-sm">
                            @Model.CourseName
                        </div>
                    </div>

                    <!-- Course Hours -->
                    <div class="col-md-6">
                        <label class="form-label text-secondary small mb-1">
                            Course Hours
                        </label>
                        <div class="p-2 px-3 bg-light border rounded shadow-sm">
                            @Model.CourseHours
                        </div>
                    </div>

                    <!-- Course Degree -->
                    <div class="col-md-6">
                        <label class="form-label text-secondary small mb-1">
                            Course Degree
                        </label>
                        <div class="p-2 px-3 bg-light border rounded shadow-sm">
                            @Model.CourseDegree
                        </div>
                    </div>

                    <!-- Minimum Degree -->
                    <div class="col-md-6">
                        <label class="form-label text-secondary small mb-1">
                            Minimum Degree
                        </label>
                        <div class="p-2 px-3 bg-light border rounded shadow-sm">
                            @Model.CourseMinDegree
                        </div>
                    </div>
                    <!-- Department -->
                    <div class="col-md-6">
                        <label class="form-label text-secondary small mb-1">
                            Department
                        </label>
                        <div class="p-2 px-3 bg-light border rounded shadow-sm">
                            @(Model.DeptName ?? "Not Assigned")
                        </div>
                    </div>


                </div>

            </div>

            <!-- Footer -->
            <div class="card-footer bg-white d-flex justify-content-between align-items-center">

                <a asp-action="Index"
                   class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
                    <i class="bi bi-arrow-left"></i>
                    Back
                </a>

                <a asp-action="Edit"
                   asp-route-id="@Model.CourseId"
                   class="btn btn-primary d-inline-flex align-items-center gap-2 px-4 shadow-sm">
                    <i class="bi bi-pencil-square"></i>
                    Edit Course
                </a>

            </div>

        </div>

    </div>
}

<style>
    .card-footer .btn {
        transition: 0.2s ease-in-out;
    }

        .card-footer .btn:hover {
            transform: translateY(-2px);
        }
</style>