@model Product

@{
    ViewData["Title"] = "Product Details";
}

@if (Model == null)
{
    <div class="alert alert-danger text-center mt-4">
        <h5 class="mb-0">Product Not Found</h5>
    </div>
}
else
{
    <div class="container py-5">

        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

            <div class="row g-0">

                <!-- Product Image -->
                <div class="col-lg-5 bg-light d-flex align-items-center justify-content-center p-4">

                    <img src="~/Images/@Model.ImageURL"
                         alt="@Model.Name"
                         class="img-fluid rounded-4"
                         style="max-height:400px; object-fit:contain;" />

                </div>

                <!-- Product Information -->
                <div class="col-lg-7">

                    <div class="card-body p-5">

                        <span class="badge bg-primary mb-3">
                            Product #@Model.Id
                        </span>

                        <h1 class="fw-bold mb-3">
                            @Model.Name
                        </h1>

                        <div class="mb-4">
                            <span class="display-6 text-success fw-bold">
                                @Model.Price EGP
                            </span>
                        </div>

                        <hr />

                        <h5 class="mb-3">
                            Description
                        </h5>

                        <p class="text-muted fs-5">
                            @(string.IsNullOrWhiteSpace(Model.Description)
                                ? "No description available."
                                : Model.Description)
                        </p>

                        <hr class="my-4" />

                        <div class="d-flex gap-2 flex-wrap">
                            
                            <a asp-action="ShowProducts"
                               class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left"></i>
                                Back
                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>
}